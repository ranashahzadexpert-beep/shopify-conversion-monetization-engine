{% comment %}
  Advanced CRO Snippet: Tiered Free Shipping Progress Bar
  Calculates thresholds dynamically via Shopify Cart API to boost AOV.
{% endcomment %}

{%- assign free_shipping_threshold = 10000 -%} {% comment %} Value in cents ($100.00) {% endcomment %}
{%- assign cart_total = cart.total_price -%}

<div id="cro-shipping-bar-wrapper" style="padding: 15px; background: #f9f9f9; border-radius: 6px; margin-bottom: 20px;">
  <div class="shipping-message" style="font-weight: 600; font-size: 14px; margin-bottom: 8px; color: #222;">
    {% if cart_total >= free_shipping_threshold %}
      🎉 Congratulations! You've unlocked **Free Worldwide Shipping**!
    {% else %}
      {% assign remaining = free_shipping_threshold | minus: cart_total %}
      You are only <span style="color: #e67e22;">{{ remaining | money }}</span> away from **FREE SHIPPING**!
    {% endif %}
  </div>

  {%- assign progress_percentage = cart_total | times: 100 | divided_by: free_shipping_threshold -%}
  {% if progress_percentage > 100 %}{% assign progress_percentage = 100 %}{% endif %}

  <div class="progress-bar-bg" style="width: 100%; height: 10px; background: #e0e0e0; border-radius: 5px; overflow: hidden;">
    <div class="progress-bar-fill" style="width: {{ progress_percentage }}%; height: 100%; background: #27ae60; transition: width 0.4s ease-in-out;"></div>
  </div>
</div>

<script>
  // High-performance AJAX listener to automatically update layout bounds without hard reloads
  document.addEventListener('cart:updated', function(event) {
    fetch(window.Shopify.routes.root + 'cart.js')
      .then(response => response.json())
      .then(cart => {
        console.log('CRO Engine: Cart snapshot re-calculated to inject updated shipping metrics seamlessly.');
        // Custom DOM manipulation logic can be wired here to refresh benchmarks dynamically
      });
  });
</script>
